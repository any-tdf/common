{
	"name": "@any-tdf/common",
	"version": "0.0.0-alpha.0",
	"description": "Framework agnostic shared utilities, theme, language packs, types and derived component utilities for any-tdf component libraries.",
	"author": "any-tdf",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/any-tdf/common"
	},
	"type": "module",
	"publishConfig": {
		"access": "public"
	},
	"files": [
		"dist",
		"readme",
		"!dist/data",
		"!dist/data/**",
		"!dist/assets",
		"!dist/assets/**"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./derived": {
			"types": "./dist/derived/index.d.ts",
			"import": "./dist/derived/index.js"
		},
		"./derived/*": {
			"types": "./dist/derived/*.d.ts",
			"import": "./dist/derived/*.js"
		},
		"./svg": {
			"types": "./dist/svg/index.d.ts",
			"import": "./dist/svg/index.js"
		},
		"./svg/*": {
			"types": "./dist/svg/*.d.ts",
			"import": "./dist/svg/*.js"
		},
		"./utils": {
			"types": "./dist/utils/index.d.ts",
			"import": "./dist/utils/index.js"
		},
		"./theme": {
			"types": "./dist/theme/index.d.ts",
			"import": "./dist/theme/index.js",
			"default": "./dist/theme/index.js"
		},
		"./theme/runtime": {
			"types": "./dist/theme/runtime.d.ts",
			"import": "./dist/theme/runtime.js",
			"default": "./dist/theme/runtime.js"
		},
		"./theme/plugin": {
			"types": "./dist/theme/plugin.d.ts",
			"import": "./dist/theme/plugin.js",
			"default": "./dist/theme/plugin.js"
		},
		"./lang": {
			"types": "./dist/lang/index.d.ts",
			"import": "./dist/lang/index.js"
		},
		"./types": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/types/index.js"
		}
	},
	"scripts": {
		"build": "rm -rf dist && NODE_OPTIONS=--max-old-space-size=1024 tsc -p tsconfig.json",
		"test": "bun test"
	},
	"peerDependencies": {
		"tailwindcss": "^4.0.0"
	},
	"peerDependenciesMeta": {
		"tailwindcss": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "^25.9.1",
		"typescript": "^6.0.3"
	}
}
